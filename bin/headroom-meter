#!/usr/bin/env python3
"""Live terminal dashboard for Headroom proxy compression logs."""

from __future__ import annotations

import argparse
import os
import re
import shutil
import signal
import sys
import time
from collections import deque
from dataclasses import dataclass
from datetime import datetime
from pathlib import Path


DEFAULT_LOG = Path.home() / ".headroom" / "logs" / "proxy.log"
VERSION = "0.2.1"

EXPLAIN_TEXT = """\
headroom-meter dashboard labels

LIVE SAVINGS SPEEDOMETER
  Current savings level for the latest completed request. This answers:
  "How much did Headroom save right now?"

NOW
  The latest request's savings percentage: tok_saved / tok_before.

ODOMETER
  Cumulative tokens saved across the log or current live-only session.

TOKEN REGEN
  Aggregate compression rate across completed requests. It is the overall
  percentage of input tokens Headroom avoided sending upstream.

RECENT REQUEST PULSES
  A sparkline of recent request savings. Taller pulses mean stronger recent
  compression spikes.

FRAME COMPRESSION
  WebSocket frame byte reduction. This shows compression happening at the
  transport/frame level, separate from request-level token savings.

SAVED TOKENS
  Total tok_saved observed by the meter.

LAST REQUEST
  Tokens saved by the most recently completed request.

REQUESTS
  Number of completed requests included in the meter, plus average tokens saved
  per completed request.

CACHE BATTERY
  Weighted average cache hit percentage from Headroom logs. Higher means more
  context is being reused from cache.

OPTIMIZE TIME
  Average time Headroom spent optimizing/compressing a request before forwarding
  it upstream.

TRANSFORMS
  Headroom transformations seen on the latest completed request, such as text,
  smart_crusher, kompress, or log compression.

TOIN
  Headroom's token/object indexing activity: patterns, compressions, retrievals,
  and retrieval rate.

Tips:
  headroom-meter --live-only    start measuring from zero
  headroom-meter --scale 10     make the gauges more sensitive
  headroom-meter --once         print a single snapshot
"""

PERF_RE = re.compile(
    r"tok_before=(?P<before>\d+).*?"
    r"tok_after=(?P<after>\d+).*?"
    r"tok_saved=(?P<saved>\d+).*?"
    r"cache_read=(?P<cache_read>\d+).*?"
    r"cache_write=(?P<cache_write>\d+).*?"
    r"cache_hit_pct=(?P<cache_hit>\d+).*?"
    r"opt_ms=(?P<opt_ms>\d+)"
)
FRAME_RE = re.compile(
    r"frame compressed (?P<before>\d+)\D+(?P<after>\d+) bytes "
    r"\((?P<saved>\d+) tokens saved"
)
TOIN_RE = re.compile(
    r"TOIN: (?P<patterns>\d+) patterns, (?P<compressions>\d+) compressions, "
    r"(?P<retrievals>\d+) retrievals, (?P<rate>[0-9.]+)% retrieval rate"
)
TS_RE = re.compile(r"^(?P<ts>\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2},\d{3})")

RESET = "\033[0m"
BOLD = "\033[1m"
DIM = "\033[2m"
RED = "\033[31m"
YELLOW = "\033[33m"
GREEN = "\033[32m"
CYAN = "\033[36m"
BLUE = "\033[34m"
MAGENTA = "\033[35m"
WHITE = "\033[37m"

BLOCKS = "▁▂▃▄▅▆▇█"
ASCII_BLOCKS = "._:-=+*#"


@dataclass
class PerfSample:
    before: int
    after: int
    saved: int
    cache_read: int
    cache_write: int
    cache_hit: int
    opt_ms: int
    line: str
    at: datetime

    @property
    def pct(self) -> float:
        return percent(self.saved, self.before)


@dataclass
class FrameSample:
    before: int
    after: int
    saved: int
    at: datetime

    @property
    def byte_pct(self) -> float:
        if self.before <= 0:
            return 0.0
        return percent(self.before - self.after, self.before)


@dataclass
class ToinSample:
    patterns: int
    compressions: int
    retrievals: int
    rate: float


class Meter:
    def __init__(self) -> None:
        self.perf_requests = 0
        self.tok_before = 0
        self.tok_after = 0
        self.tok_saved = 0
        self.cache_weighted = 0
        self.cache_weight = 0
        self.opt_ms_total = 0
        self.frame_count = 0
        self.frame_before = 0
        self.frame_after = 0
        self.frame_tokens_saved = 0
        self.last_perf: PerfSample | None = None
        self.last_frame: FrameSample | None = None
        self.last_toin: ToinSample | None = None
        self.last_event_at: datetime | None = None
        self.recent_pct: deque[float] = deque(maxlen=72)
        self.recent_saved: deque[int] = deque(maxlen=72)
        self.recent_frame_pct: deque[float] = deque(maxlen=72)

    def add_line(self, line: str) -> bool:
        changed = False
        timestamp = parse_timestamp(line) or datetime.now()

        # Headroom currently emits duplicate PERF lines; only the line with
        # total_ms represents the completed request.
        if " PERF " in line and "total_ms=" in line:
            match = PERF_RE.search(line)
            if match:
                sample = PerfSample(
                    before=int(match.group("before")),
                    after=int(match.group("after")),
                    saved=int(match.group("saved")),
                    cache_read=int(match.group("cache_read")),
                    cache_write=int(match.group("cache_write")),
                    cache_hit=int(match.group("cache_hit")),
                    opt_ms=int(match.group("opt_ms")),
                    line=line.rstrip(),
                    at=timestamp,
                )
                self.perf_requests += 1
                self.tok_before += sample.before
                self.tok_after += sample.after
                self.tok_saved += sample.saved
                self.cache_weighted += sample.cache_hit * max(sample.before, 1)
                self.cache_weight += max(sample.before, 1)
                self.opt_ms_total += sample.opt_ms
                self.last_perf = sample
                self.last_event_at = timestamp
                self.recent_pct.append(sample.pct)
                self.recent_saved.append(sample.saved)
                changed = True

        if "frame compressed" in line:
            match = FRAME_RE.search(line)
            if match:
                sample = FrameSample(
                    before=int(match.group("before")),
                    after=int(match.group("after")),
                    saved=int(match.group("saved")),
                    at=timestamp,
                )
                self.frame_count += 1
                self.frame_before += sample.before
                self.frame_after += sample.after
                self.frame_tokens_saved += sample.saved
                self.last_frame = sample
                self.last_event_at = timestamp
                self.recent_frame_pct.append(sample.byte_pct)
                changed = True

        if "TOIN:" in line:
            match = TOIN_RE.search(line)
            if match:
                self.last_toin = ToinSample(
                    patterns=int(match.group("patterns")),
                    compressions=int(match.group("compressions")),
                    retrievals=int(match.group("retrievals")),
                    rate=float(match.group("rate")),
                )
                self.last_event_at = timestamp
                changed = True

        return changed

    @property
    def token_savings_pct(self) -> float:
        return percent(self.tok_saved, self.tok_before)

    @property
    def byte_savings_pct(self) -> float:
        if self.frame_before <= 0:
            return 0.0
        return percent(self.frame_before - self.frame_after, self.frame_before)

    @property
    def avg_cache_hit(self) -> float:
        if self.cache_weight <= 0:
            return 0.0
        return self.cache_weighted / self.cache_weight

    @property
    def avg_opt_ms(self) -> float:
        if self.perf_requests <= 0:
            return 0.0
        return self.opt_ms_total / self.perf_requests

    @property
    def avg_saved(self) -> float:
        if self.perf_requests <= 0:
            return 0.0
        return self.tok_saved / self.perf_requests


def parse_timestamp(line: str) -> datetime | None:
    match = TS_RE.match(line)
    if not match:
        return None
    try:
        return datetime.strptime(match.group("ts"), "%Y-%m-%d %H:%M:%S,%f")
    except ValueError:
        return None


def percent(part: int | float, whole: int | float) -> float:
    if whole <= 0:
        return 0.0
    return 100.0 * part / whole


def fmt_int(value: int | float) -> str:
    return f"{int(value):,}"


def fmt_age(dt: datetime | None) -> str:
    if dt is None:
        return "no events yet"
    seconds = max(0, int((datetime.now() - dt).total_seconds()))
    if seconds < 60:
        return f"{seconds}s ago"
    minutes, seconds = divmod(seconds, 60)
    if minutes < 60:
        return f"{minutes}m {seconds}s ago"
    hours, minutes = divmod(minutes, 60)
    return f"{hours}h {minutes}m ago"


def color(text: str, code: str, enabled: bool) -> str:
    if not enabled:
        return text
    return f"{code}{text}{RESET}"


def compression_color(value: float) -> str:
    if value >= 8:
        return GREEN
    if value >= 3:
        return CYAN
    if value > 0:
        return YELLOW
    return DIM


def health_color(label: str) -> str:
    if label == "ACTIVE":
        return GREEN
    if label == "IDLE":
        return YELLOW
    if label == "STALE":
        return RED
    return DIM


def status_label(meter: Meter) -> str:
    if meter.last_event_at is None:
        return "WAITING"
    seconds = (datetime.now() - meter.last_event_at).total_seconds()
    if seconds < 30:
        return "ACTIVE"
    if seconds < 180:
        return "IDLE"
    return "STALE"


def gauge(
    value: float,
    *,
    scale: float,
    width: int,
    use_color: bool,
    ascii_mode: bool,
    active_color: str | None = None,
) -> str:
    if width <= 0:
        return ""
    ratio = 0.0 if scale <= 0 else min(max(value / scale, 0.0), 1.0)
    filled = round(ratio * width)
    fill = "#" if ascii_mode else "█"
    empty = "-" if ascii_mode else "░"
    bar = fill * filled + empty * (width - filled)
    return color(bar, active_color or compression_color(value), use_color)


def sparkline(
    values: deque[float],
    *,
    width: int,
    scale: float,
    use_color: bool,
    ascii_mode: bool,
) -> str:
    if width <= 0:
        return ""
    if not values:
        empty = "." if ascii_mode else "·"
        return color(empty * width, DIM, use_color)

    blocks = ASCII_BLOCKS if ascii_mode else BLOCKS
    data = list(values)[-width:]
    if len(data) < width:
        data = [0.0] * (width - len(data)) + data
    top = max(scale, max(data), 0.01)
    chars = []
    for value in data:
        ratio = min(max(value / top, 0.0), 1.0)
        idx = min(round(ratio * (len(blocks) - 1)), len(blocks) - 1)
        chars.append(blocks[idx])
    return color("".join(chars), compression_color(max(data)), use_color)


def place_labels(width: int, labels: list[tuple[int, str]]) -> str:
    chars = [" "] * max(width, 1)
    for pos, text in labels:
        start = min(max(pos - len(text) // 2, 0), max(len(chars) - len(text), 0))
        for offset, char in enumerate(text):
            idx = start + offset
            if 0 <= idx < len(chars):
                chars[idx] = char
    return "".join(chars).rstrip()


def speedometer(
    value: float,
    *,
    saved_tokens: int,
    total_saved: int,
    scale: float,
    width: int,
    use_color: bool,
    ascii_mode: bool,
) -> list[str]:
    dial_width = min(max(width - 6, 34), 76)
    ratio = 0.0 if scale <= 0 else min(max(value / scale, 0.0), 1.0)
    needle = round(ratio * (dial_width - 1))
    half = round((dial_width - 1) / 2)

    if ascii_mode:
        left_cap, right_cap, fill, empty, needle_char = "[", "]", "=", "-", "^"
    else:
        left_cap, right_cap, fill, empty, needle_char = "╭", "╮", "━", "─", "▲"

    track = fill * needle + needle_char + empty * max(dial_width - needle - 1, 0)
    dial = f"  {left_cap}{color(track, compression_color(value), use_color)}{right_cap}"
    labels = place_labels(
        dial_width + 2,
        [
            (0, "0%"),
            (half, f"{scale / 2:g}%"),
            (dial_width + 1, f"{scale:g}%+"),
        ],
    )
    readout = (
        f"  {color(f'{value:5.2f}% NOW', BOLD + compression_color(value), use_color)}  "
        f"{fmt_int(saved_tokens)} saved last request  "
        f"{color('ODOMETER', DIM, use_color)} {fmt_int(total_saved)} tokens"
    )
    return [f"  {color(labels, DIM, use_color)}", dial, readout]


def short_transforms(line: str | None) -> str:
    if not line or "transforms=" not in line:
        return "none"
    raw = line.split("transforms=", 1)[1].split(" client=", 1)[0]
    names: list[str] = []
    for token in raw.split():
        name = token.rsplit(":", 1)[-1]
        if name and name not in names:
            names.append(name)
    return ", ".join(names[:6]) or "none"


def metric(label: str, value: str, width: int, use_color: bool) -> str:
    label_part = color(label.upper().ljust(16), DIM, use_color)
    return f"{label_part} {value}".ljust(width)


def render(meter: Meter, log_path: Path, scale: float, use_color: bool, ascii_mode: bool) -> str:
    columns = shutil.get_terminal_size((100, 30)).columns
    width = min(max(columns - 4, 76), 118)
    gauge_width = min(max(width - 33, 28), 62)
    spark_width = min(max(width - 30, 32), 72)
    speedometer_width = min(max(width - 4, 52), 96)

    saving_pct = meter.token_savings_pct
    byte_pct = meter.byte_savings_pct
    status = status_label(meter)
    last_saved = meter.last_perf.saved if meter.last_perf else 0
    last_before = meter.last_perf.before if meter.last_perf else 0
    last_pct = percent(last_saved, last_before)
    last_frame_pct = meter.last_frame.byte_pct if meter.last_frame else 0.0

    title = color("HEADROOM REGEN DASHBOARD", BOLD + CYAN, use_color)
    status_text = color(status, BOLD + health_color(status), use_color)
    dim_log = color(str(log_path), DIM, use_color)
    rule = color("=" * width, DIM, use_color)
    subrule = color("-" * width, DIM, use_color)

    lines = [
        title,
        f"Status {status_text}  Last event {fmt_age(meter.last_event_at)}  Log {dim_log}",
        rule,
        "",
        color("LIVE SAVINGS SPEEDOMETER", BOLD + WHITE, use_color),
        *speedometer(
            last_pct,
            saved_tokens=last_saved,
            total_saved=meter.tok_saved,
            scale=scale,
            width=speedometer_width,
            use_color=use_color,
            ascii_mode=ascii_mode,
        ),
        "",
        color("TOKEN REGEN", BOLD + WHITE, use_color),
        f"  {gauge(saving_pct, scale=scale, width=gauge_width, use_color=use_color, ascii_mode=ascii_mode)} "
        f"{saving_pct:5.2f}% captured  "
        f"{color('(full scale: ' + f'{scale:g}%' + ')', DIM, use_color)}",
        "",
        color("RECENT REQUEST PULSES", BOLD + WHITE, use_color),
        f"  {sparkline(meter.recent_pct, width=spark_width, scale=scale, use_color=use_color, ascii_mode=ascii_mode)}",
        f"  last {last_pct:5.2f}%  avg {saving_pct:5.2f}%  peak {max(meter.recent_pct or [0.0]):5.2f}%",
        "",
        color("FRAME COMPRESSION", BOLD + WHITE, use_color),
        f"  {gauge(byte_pct, scale=scale, width=gauge_width, use_color=use_color, ascii_mode=ascii_mode, active_color=BLUE)} "
        f"{byte_pct:5.2f}% byte reduction  last frame {last_frame_pct:5.2f}%",
        f"  {sparkline(meter.recent_frame_pct, width=spark_width, scale=scale, use_color=use_color, ascii_mode=ascii_mode)}",
        "",
        subrule,
        metric("saved tokens", f"{color(fmt_int(meter.tok_saved), BOLD + GREEN, use_color)} total", width, use_color),
        metric("last request", f"{fmt_int(last_saved)} saved from {fmt_int(last_before)}", width, use_color),
        metric("requests", f"{fmt_int(meter.perf_requests)} completed, {fmt_int(meter.avg_saved)} avg saved", width, use_color),
        metric("cache battery", f"{gauge(meter.avg_cache_hit, scale=100, width=24, use_color=use_color, ascii_mode=ascii_mode, active_color=GREEN)} {meter.avg_cache_hit:5.1f}%", width, use_color),
        metric("optimize time", f"{meter.avg_opt_ms:,.0f} ms avg", width, use_color),
        metric("transforms", short_transforms(meter.last_perf.line if meter.last_perf else None), width, use_color),
    ]

    if meter.last_toin:
        lines.append(
            metric(
                "toin",
                f"{fmt_int(meter.last_toin.patterns)} patterns, "
                f"{fmt_int(meter.last_toin.compressions)} compressions, "
                f"{fmt_int(meter.last_toin.retrievals)} retrievals "
                f"({meter.last_toin.rate:.1f}% retrieval)",
                width,
                use_color,
            )
        )

    lines.extend(["", color("Ctrl-C to exit.", DIM, use_color)])
    return "\n".join(lines)


def clear_and_print(text: str) -> None:
    sys.stdout.write("\033[H\033[J")
    sys.stdout.write(text)
    sys.stdout.flush()


def enter_live_screen(use_alt_screen: bool) -> None:
    if use_alt_screen:
        sys.stdout.write("\033[?1049h")
    sys.stdout.write("\033[?25l")
    sys.stdout.write("\033[H\033[J")
    sys.stdout.flush()


def exit_live_screen(use_alt_screen: bool) -> None:
    sys.stdout.write("\033[?25h")
    if use_alt_screen:
        sys.stdout.write("\033[?1049l")
    else:
        sys.stdout.write("\n")
    sys.stdout.flush()


def read_available(handle, meter: Meter) -> bool:
    changed = False
    while True:
        line = handle.readline()
        if not line:
            break
        changed = meter.add_line(line) or changed
    return changed


def open_log(path: Path):
    while True:
        try:
            return path.open("r", encoding="utf-8", errors="replace")
        except FileNotFoundError:
            time.sleep(1.0)


def color_enabled(mode: str) -> bool:
    if mode == "always":
        return True
    if mode == "never":
        return False
    return sys.stdout.isatty() and os.environ.get("NO_COLOR") is None


def main() -> int:
    if any(arg in {"/help", "help", "explain"} for arg in sys.argv[1:]):
        print(EXPLAIN_TEXT)
        return 0

    parser = argparse.ArgumentParser(
        description="Show a live terminal dashboard for Headroom compression."
    )
    parser.add_argument(
        "--version",
        action="version",
        version=f"headroom-meter {VERSION}",
    )
    parser.add_argument(
        "--explain",
        action="store_true",
        help="Explain dashboard labels and exit.",
    )
    parser.add_argument(
        "--log",
        type=Path,
        default=DEFAULT_LOG,
        help=f"Headroom proxy log path. Default: {DEFAULT_LOG}",
    )
    parser.add_argument(
        "--live-only",
        action="store_true",
        help="Ignore existing log contents and count only new events.",
    )
    parser.add_argument(
        "--once",
        action="store_true",
        help="Print one snapshot and exit.",
    )
    parser.add_argument(
        "--scale",
        type=float,
        default=25.0,
        help="Savings percent that fills the bars. Default: 25.",
    )
    parser.add_argument(
        "--interval",
        type=float,
        default=1.0,
        help="Refresh interval in seconds. Default: 1.",
    )
    parser.add_argument(
        "--color",
        choices=("auto", "always", "never"),
        default="auto",
        help="Color output mode. Default: auto.",
    )
    parser.add_argument(
        "--ascii",
        action="store_true",
        help="Use ASCII bars instead of Unicode block graphs.",
    )
    parser.add_argument(
        "--no-alt-screen",
        action="store_true",
        help="Do not use the terminal alternate screen in live mode.",
    )
    args = parser.parse_args()

    if args.explain:
        print(EXPLAIN_TEXT)
        return 0

    meter = Meter()
    log_path = args.log.expanduser()
    handle = open_log(log_path)
    use_color = color_enabled(args.color)

    if args.live_only:
        handle.seek(0, os.SEEK_END)
    else:
        read_available(handle, meter)

    if args.once:
        print(render(meter, log_path, args.scale, use_color, args.ascii))
        return 0

    stop = False

    def request_stop(_signum, _frame) -> None:
        nonlocal stop
        stop = True

    signal.signal(signal.SIGINT, request_stop)
    signal.signal(signal.SIGTERM, request_stop)

    use_alt_screen = not args.no_alt_screen and sys.stdout.isatty()

    try:
        enter_live_screen(use_alt_screen)
        while not stop:
            read_available(handle, meter)
            clear_and_print(render(meter, log_path, args.scale, use_color, args.ascii))
            time.sleep(max(args.interval, 0.1))

            try:
                stat = log_path.stat()
            except FileNotFoundError:
                continue
            if handle.tell() > stat.st_size:
                handle.close()
                handle = open_log(log_path)
    finally:
        try:
            handle.close()
        finally:
            exit_live_screen(use_alt_screen)

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
